<edmx:Edmx xmlns:edmx="http://docs.oasis-open.org/odata/ns/edmx" Version="4.0">
    <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/Common.xml">
        <edmx:Include Namespace="com.sap.vocabularies.Common.v1" Alias="Common"/>
    </edmx:Reference>
    <edmx:Reference Uri="https://sap.github.io/odata-vocabularies/vocabularies/UI.xml">
        <edmx:Include Namespace="com.sap.vocabularies.UI.v1" Alias="UI"/>
    </edmx:Reference>
    <edmx:DataServices>
        <Schema xmlns="http://docs.oasis-open.org/odata/ns/edm" Namespace="MasterDataService">
            <EntityType Name="BusinessPartners">
                <Key>
                    <PropertyRef Name="ID"/>
                </Key>
                <Property Name="ID" Type="Edm.Guid" Nullable="false"/>
                <Property Name="businessPartnerNumber" Type="Edm.String" MaxLength="20"/>
                <Property Name="vendorCode" Type="Edm.String" MaxLength="10"/>
                <Property Name="customerCode" Type="Edm.String" MaxLength="10"/>
                <Property Name="businessPartnerName1" Type="Edm.String" MaxLength="40"/>
                <Property Name="businessPartnerName2" Type="Edm.String" MaxLength="40"/>
                <Property Name="address" Type="Edm.String" MaxLength="10"/>
            </EntityType>
            <EntityContainer Name="EntityContainer">
                <EntitySet Name="BusinessPartners" EntityType="MasterDataService.BusinessPartners"/>
            </EntityContainer>
        </Schema>
    </edmx:DataServices>
</edmx:Edmx>