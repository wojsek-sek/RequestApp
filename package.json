{
  "name": "CAPMAP",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap-cloud-sdk/connectivity": "^4",
    "@sap-cloud-sdk/http-client": "^4",
    "@sap-cloud-sdk/resilience": "^4.5.1",
    "@sap/cds": "^9",
    "@sap/hdi-deploy": "^5.6.1",
    "@sap/xssec": "^4"
  },
  "devDependencies": {
    "@cap-js/cds-typer": ">=0.1",
    "@cap-js/cds-types": "^0.15.0",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@sapui5/types": "^1.146.0",
    "@types/node": "^24.0.0",
    "cds-plugin-ui5": "^0.13.0",
    "mbt": "^1.2.45",
    "tsx": "^4",
    "typescript": "^5"
  },
  "scripts": {
    "start": "npx cds-serve",
    "watch": "cds watch",
    "build": "mbt build",
    "watch-requestsui": "cds watch --open capmap.requestsui/index.html?sap-ui-xx-viewCache=false --livereload false"
  },
  "imports": {
    "#cds-models/*": "./@cds-models/*/index.js"
  },
  "cds": {
    "requires": {
      "[production]": {
        "db": "hana",
        "auth": "xsuaa"
      },
      "API_COSTCENTER_V2": {
        "kind": "odata-v2",
        "model": "srv/external/API_COSTCENTER_V2",
        "credentials": {
          "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_COSTCENTER_SRV"
        }
      },
      "PACBusinessPartner": {
        "kind": "odata-v4",
        "model": "srv/external/API_BUSINESS_PARTNER_V4",
        "credentials": {
          "url": "https://sandbox.api.sap.com/PackagingAgreementsCollaboration/odata/v4/MasterDataService"
        }
      },
      "destinations": true,
      "connectivity": true,
      "html5-repo": true
    }
  },
  "workspaces": [
    "app/*"
  ],
  "sapux": [
    "app/requestsui"
  ]
}
