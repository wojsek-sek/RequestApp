{
    "requires": {
      "[production]": {
        "db": "hana",
        "auth": "xsuaa"
      },
      "db": {
        "kind": "sqlite",
        "credentials": {
          "url": "db.sqlite"
        }
      },
      "auth": {
        "users": {
          "admin-eu": {
            "password" : "test",
            "roles": ["RegionalManager"],
            "attr": {
              "Region": ["EU","PL","EN"]
            }
          },
          "admin-us": {
            "password" : "test2",
            "roles": ["RegionalManager"],
            "attr": {
              "Region": ["US","EU"]
            }
          },
          "readonly-user": {
            "roles": ["Viewer"]
          }
        }
      },
      "API_COSTCENTER_V2": {
        "kind": "odata-v2",
        "model": "srv/external/API_COSTCENTER_V2",
        "[development]" : {
          "credentials": {
            "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_COSTCENTER_SRV"
          }
        },
        "[production]": {
          "credentials": {
            "destination": "S4HANA_DESTINATION",
            "path": "/sap/opu/odata/sap/API_COSTCENTER_V2"
          }
        }
      },
      "API_BUSINESS_PARTNER": {
        "kind": "odata-v2",
        "model": "srv/external/API_BUSINESS_PARTNER",
        "[development]": {
          "credentials": {
            "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_BUSINESS_PARTNER"
          }
        },
        "[production]": {
          "credentials": {
            "destination": "S4HANA_DESTINATION",
            "path": "/sap/opu/odata/sap/API_BUSINESS_PARTNER"
          }
        }
      },
      "API_PRODUCT_SRV": {
        "kind": "odata-v2",
        "model": "srv/external/API_PRODUCT_SRV",
        "[development]" : {
          "credentials": {
            "url": "https://sandbox.api.sap.com/s4hanacloud/sap/opu/odata/sap/API_PRODUCT_SRV"
          }
        },
        "[production]": {
          "credentials": {
            "destination": "S4HANA_DESTINATION",
            "path": "/sap/opu/odata/sap/API_PRODUCT_SRV"
          }
        }
      },
      "destinations": true,
      "connectivity": true,
      "html5-repo": true,
      "[development]": {
        "AI_Agent_Hub": {
          "kind": "mock",
          "impl": "srv/mocks/ai-agent-hub-mock.js"
        },
        "VectorEngine": {
          "kind": "local-vector-mock",
          "impl": "srv/mocks/vector-engine-mock.js"
        }
      },
      "[test]": {
        "db": {
          "credentials": { "url": ":memory:" }
        },
        "AI_Agent_Hub": {
          "kind": "mock",
          "impl": "srv/mocks/ai-agent-hub-mock.js"
        }
      }
    }
  }
  